# 复制为项目根目录的 .env 后由 docker compose 自动加载
# copy .env.docker.example .env

# PostgreSQL（与 docker-compose 中默认值一致时可不改）
POSTGRES_USER=ecommercepic
POSTGRES_PASSWORD=ecommercepic_change_me
POSTGRES_DB=ecommercepic
POSTGRES_PORT=5432

# 应用
APP_PORT=3000

# 可选：启用 Redis 时
# REDIS_PORT=6379

# Cloudflare Worker — 详见 docs/CLOUDFLARE.md（MVP 只配 URL 即可）
# CLOUDFLARE_WORKER_URL=https://your-worker.xxx.workers.dev
# 或: WORKER_URL=https://...
# 可选 Bearer：CLOUDFLARE_WORKER_SECRET= 或 WORKER_SECRET=

# Ubuntu 编排（docker-compose.ubuntu.yml）对外 HTTP 端口
# UBUNTU_HTTP_PORT=80
