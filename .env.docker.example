# 复制为项目根目录的 .env 后由 docker compose 自动加载
# copy .env.docker.example .env

# PostgreSQL（与 docker-compose 中默认值一致时可不改）
POSTGRES_USER=ecommercepic
POSTGRES_PASSWORD=ecommercepic_change_me
POSTGRES_DB=ecommercepic
POSTGRES_PORT=5432

# 应用
APP_PORT=3000

# 可选：启用 Redis 时
# REDIS_PORT=6379

# Cloudflare Worker — 详见 docs/CLOUDFLARE.md（MVP 只配 URL 即可）
# CLOUDFLARE_WORKER_URL=https://your-worker.xxx.workers.dev
# 或: WORKER_URL=https://...
# 可选 Bearer：CLOUDFLARE_WORKER_SECRET= 或 WORKER_SECRET=

# 火山方舟 Seedream（产品图作参考图传入；与 Worker 并存时默认先用 Worker）
# ARK_API_KEY=你的方舟 API Key
# ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# ARK_IMAGE_MODEL=doubao-seedream-5-0-260128
# ARK_IMAGE_SIZE=2K
# ARK_WATERMARK=false
# 强制用 Ark：IMAGE_GENERATION_PROVIDER=ark
# 强制用 Cloudflare：IMAGE_GENERATION_PROVIDER=cloudflare

# 文案 / 提示词（/api/prompts/generate）：火山方舟 Responses API
# TEXT_LLM_PROVIDER=ark
# TEXT_LLM_PROVIDER=template
# ARK_TEXT_MODEL=doubao-seed-2-0-lite-260215
# （可与生图共用 ARK_API_KEY、ARK_BASE_URL）

# Ubuntu 编排（docker-compose.ubuntu.yml）对外 HTTP 端口
# UBUNTU_HTTP_PORT=80
